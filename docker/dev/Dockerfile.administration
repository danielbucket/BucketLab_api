# Dockerfile for Administration Service - Development
FROM node:22-alpine

# Install required packages
RUN apk --no-cache add curl

# Create app directory
WORKDIR /administration

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
  adduser -S bucketlab -u 1001

# Copy package files for dependency caching
COPY database_servers/administration/package*.json ./

# Install all dependencies (including dev for nodemon, jest, etc.)
RUN npm ci --no-audit --no-fund && \
  npm cache clean --force

# Copy application code
COPY database_servers/administration/ ./

# Fix ownership
RUN chown -R bucketlab:nodejs /administration

# Switch to non-root user
USER bucketlab

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -f http://localhost:4027/health || exit 1

# Expose port
EXPOSE 4027

# Start application with nodemon for hot reload
CMD ["npm", "run", "start:dev"]
